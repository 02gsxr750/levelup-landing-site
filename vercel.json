{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/challenge/:id", "destination": "/api/challenge-og?id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
